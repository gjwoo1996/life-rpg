# Dependencies
node_modules/

# Build output (regenerated by npm run build / tauri build)
dist/

# Env and secrets
.env
.env.local
.env.*.local

# Logs and debug
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# IDE / Editor (not required for CI build)
.idea/
*.iml
.vscode/
.cursor/

# Cache
.cache/
.parcel-cache/

# Test and coverage (optional, not needed for exe build)
coverage/
.nyc_output/

# Local Rust build artifacts (src-tauri/target already in src-tauri/.gitignore)
*.exe
*.pdb
